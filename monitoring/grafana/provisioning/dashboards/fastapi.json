              {
                "color": "red",
                "value": 0.1
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
