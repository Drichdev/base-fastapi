# ===========================
# APPLICATION
# ===========================
APP_NAME=BaseFastAPIPro
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_VERSION=1.0.0

# ===========================
# MONGODB
# ===========================
MONGODB_URL=mongodb://mongo:27017
MONGODB_DATABASE=base_fastapi_pro

# ===========================
# JWT AUTHENTICATION
# ===========================
JWT_SECRET_KEY=change-me-to-a-very-long-random-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ===========================
# REDIS
# ===========================
REDIS_URL=redis://redis:6379/0

# ===========================
# CELERY
# ===========================
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ===========================
# EMAIL (SMTP)
# ===========================
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@example.com
MAIL_FROM_NAME=BaseFastAPIPro
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_STARTTLS=true
MAIL_SSL_TLS=false

# ===========================
# CORS
# ===========================
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ===========================
# RATE LIMITING
# ===========================
RATE_LIMIT_PER_MINUTE=60

# ===========================
# ADMIN (premier admin créé au démarrage)
# ===========================
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123456
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=System
